{
  "name": "@shcherbin/eslint-config-node",
  "description": "Shareable eslint Node.js config",
  "version": "0.6.0",
  "author": "Vlad Shcherbin <vlad.shcherbin@gmail.com>",
  "repository": "vladshcherbin/eslint-config-node",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "prepublishOnly": "pnpm lint && pnpm build"
  },
  "dependencies": {
    "@shcherbin/eslint-config": "^0.20.1",
    "globals": "^17.6.0"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint": "^10.3.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">= 26"
  },
  "sideEffects": false,
  "type": "module",
  "license": "MIT"
}
